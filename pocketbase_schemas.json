    "log_comunicaciones": {
      "id": "log_comunicaciones",
      "type": "base",
      "purpose": "Audit trail for all communications (email, SMS, push, WhatsApp)",
      "api_rules": {
        "list": "@request.auth.hacienda.id != '' && metadata ? @request.auth.hacienda.id = metadata.hacienda_id : false || @request.auth.role = 'superadmin'",
        "view": "Same as list rule",
        "create": "@request.auth.id != ''",
        "update": "false (immutable audit trail)",
        "delete": "@request.auth.role = 'superadmin'"
      },
      "fields": {
        "tipo": "select ['email', 'sms', 'push_notification', 'whatsapp'] - required, default: 'email'",
        "destinatario": "text (required, max_length: 500)",
        "asunto": "text (nullable, max_length: 200)",
        "estado": "select ['sent', 'failed', 'pending', 'mock'] - required, default: 'pending'",
        "resend_id": "text (nullable, max_length: 100) - Resend API message ID",
        "error": "text (nullable, max_length: 1000)",
        "metadata": "json (maxSize: 2MB) - includes timestamp, reportType, hacienda_id, user_id",
        "created": "date (auto, system field)",
        "updated": "date (auto, system field)"
      },
      "indexes": [
        "idx_log_comunicaciones_tipo (tipo)",
        "idx_log_comunicaciones_estado (estado)",
        "idx_log_comunicaciones_created (created DESC)",
        "idx_log_comunicaciones_hacienda (metadata.hacienda_id)"
      ]
    }
